{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    // Developer preset - shows dev tool versions

    "logo": {
        "source": "apple",
        "padding": { "top": 1, "left": 2, "right": 3 },
        "color": { "1": "36" }
    },

    "display": {
        "separator": "  ",
        "color": { "keys": "36", "output": "white" }
    },

    "modules": [
        {
            "type": "title",
            "format": "{user-name-colored}{at-symbol-colored}{host-name-colored}"
        },
        {
            "type": "custom",
            "format": "────────────────────────────"
        },
        { "type": "os", "key": "  sys" },
        { "type": "uptime", "key": "   up" },
        { "type": "memory", "key": "  mem" },
        {
            "type": "custom",
            "format": "────────────────────────────"
        },
        { "type": "shell", "key": "  sh" },
        { "type": "terminal", "key": "  term" },
        {
            "type": "command",
            "key": "  nvim",
            "text": "nvim --version 2>/dev/null | head -1 | cut -d' ' -f2 || echo 'not installed'"
        },
        {
            "type": "command",
            "key": "  node",
            "text": "node --version 2>/dev/null | tr -d 'v' || echo 'not installed'"
        },
        {
            "type": "command",
            "key": "  git",
            "text": "git --version 2>/dev/null | cut -d' ' -f3 || echo 'not installed'"
        },
        {
            "type": "command",
            "key": "  go",
            "text": "go version 2>/dev/null | cut -d' ' -f3 | tr -d 'go' || echo 'not installed'"
        },
        {
            "type": "custom",
            "format": "────────────────────────────"
        },
        {
            "type": "command",
            "key": "  brew",
            "text": "brew list --formula 2>/dev/null | wc -l | tr -d ' '"
        },
        "break",
        { "type": "colors", "symbol": "circle" }
    ]
}
