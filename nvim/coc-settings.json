{
  "suggest.noselect": true,
  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod"],
      "filetypes": ["go"]
    },
    "zk": {
      "command": "zk",
      "args": ["lsp"],
      "filetypes": ["markdown"],
      "rootPatterns": ["zk.toml", ".git"],
      "trace.server": "off"
    }
  }
}
