{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 0,
    "margin-top": 4,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "network",
        "wireplumber",
        "battery",
        "tray",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "format": "[{name}]",
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
        "sort-by-number": true,
        "active-only": false
    },

    "clock": {
        "format": "{:%a %d %b | %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "interval": 5,
        "format": "cpu:{usage}%",
        "max-length": 10
    },

    "memory": {
        "interval": 10,
        "format": "mem:{percentage}%",
        "tooltip-format": "{used:0.1f}GB / {total:0.0f}GB"
    },

    "network": {
        "interval": 5,
        "format-wifi": "wifi:{signalStrength}% {icon}",
        "format-icons": ["____", "|___", "||__", "|||_", "||||"],
        "format-ethernet": "eth:up",
        "format-disconnected": "wifi:--",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "wireplumber": {
        "format": "vol:{volume}%",
        "format-muted": "vol:mute",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "bat:{capacity}%",
        "format-charging": "bat:{capacity}%+",
        "format-plugged": "bat:ac"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    },

    "custom/power": {
        "format": "[x]",
        "tooltip": false,
        "on-click": "wlogout"
    }
}
