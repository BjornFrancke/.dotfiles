// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
	"outline_panel": {
  "indent_guides": {
   "show": "always"
  },
  "folder_icons": true,
  "file_icons": true,
  "button": true
 },
 "preview_tabs": {
  "enable_preview_from_file_finder": true
 },
 "diagnostics": {
  "button": true
 },
 "debugger": {
  "button": false
 },
 "terminal": {
  "button": false
 },
 "which_key": {
  "enabled": true
 },
 "bottom_dock_layout": "contained",
 "tab_size": 2,
 "auto_signature_help": false,
 "agent_ui_font_size": 12.0,
 "buffer_font_weight": 400.0,
 "edit_predictions": {
  "provider": "zed",
  "mode": "subtle"
 },
 "agent_servers": {
  "opencode": {
   "type": "registry"
  },
  "w": {
   "type": "custom",
   "command": "path_to_executable",
   "args": [],
   "env": {}
  }
 },
 "git": {
  "disable_git": false,
  "blame": {
   "show_avatar": false
  }
 },
 "inline_code_actions": false,
 "languages": {
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } }
	},
	"show_edit_predictions": false,
	"vim_mode": false,
	// UI Config
	"icon_theme": "Material Icon Theme",
	"base_keymap": "VSCode",
	"ui_font_size": 12.0,
	"buffer_font_size": 12,
	"ui_font_family": "JetBrainsMono Nerd Font Mono",
	"buffer_font_family": "JetBrainsMono Nerd Font Mono",
	"theme": "Ayu Darker",
	// Status bar
	"line_indicator_format": "short",
	"title_bar": {
		"show_project_items": true,
  "show_branch_icon": false,
		"show_user_picture": false,
		"show_onboarding_banner": false,
		"show_menus": false,
		"show_sign_in": false
	},
	"unnecessary_code_fade": 0.3,

	"gutter": {
		"line_numbers": true, // Show/hide line numbers in the gutter.
		"runnables": false, // Show/hide runnables buttons in the gutter.
		"breakpoints": false, // Show/hide show breakpoints in the gutter.
		"folds": false, // Show/hide show fold buttons in the gutter.
		"min_line_number_digits": 3 // Reserve space for N digit line numbers
	},

	"toolbar": {
		"selections_menu": false,
		"agent_review": false,
		"quick_actions": false
	},

	"project_panel": {
		"bold_folder_labels": true,
  "default_width": 230.0,
  "dock": "right",
		"button": false,
		"git_status": true,
		"indent_size": 13.0,
		"sticky_scroll": true,
		"entry_spacing": "standard",
		"scrollbar": { "show": "never" },
		"hide_root": true,
		"indent_guides": { "show": "always" }
	},

	"status_bar": {
		"cursor_position_button": false
	},

	"notification_panel": {
		"button": false,
  "dock": "left"
	},
	"agent": {
		"default_profile": "write",
		"dock": "right",
		"default_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4-5"
		},
		"commit_message_model": {
      "provider": "openai",
      "model": "gpt-4o-mini"
    },
	},

	"max_tabs": 6,

	"collaboration_panel": {
		"button": false
	},
	"tab_bar": {
		"show_pinned_tabs_in_separate_row": false,
  "show": true,
		"show_nav_history_buttons": false,
		"show_tab_bar_buttons": false
	},
	"tabs": {
		"show_diagnostics": "off",
  "show_close_button": "hidden",
		"file_icons": true,
		"git_status": false
	},
	"file_scan_exclusions": [
		"**/.git",
		"**/.svn",
		"**/.hg",
		"**/CVS",
		"**/.DS_Store",
		"**/Thumbs.db",
		"**/.classpath",
		"**/.settings",
		"**/dist",
		"**/.vscode"
	],
	"relative_line_numbers": "disabled",
	"autosave": {
  "after_delay": {
   "milliseconds": 1000
  }
 },
	// Whether to show full labels in line indicator or short ones
	//   - `short`: "2 s, 15 l, 32 c"
	//   - `long`: "2 selections, 15 lines, 32 characters"

	"auto_indent": true,
	"git_panel": { "tree_view": true,
                "default_width": 300.0,
                "dock": "right",
                "button": true },
	"search": { "button": false },

	"inlay_hints": { "show_background": false,
                  "show_parameter_hints": true,
                  "show_other_hints": false,
                  "show_type_hints": false,
                  "show_value_hints": false,
                  "enabled": true },
	"cursor_blink": true,
	"indent_guides": {
		"enabled": true,
		"coloring": "indent_aware",
		"line_width": 3,
		"background_coloring": "disabled"
	},
	"lsp": {
		"biome": {
  	 "binary": {
          "path": "/opt/homebrew/bin/biome",
          "arguments": ["lsp-proxy"]
        },
			"settings": {
			  "require_config_file": true
			}
		}
	}
}
